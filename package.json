{
  "name": "skhaall-codeguard",
  "version": "0.1.0",
  "description": "MCP server — analyse de code TypeScript/Prisma, graphe de dependances, impact analysis pour Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "codeguard": "dist/index.js",
    "codeguard-cli": "dist/cli.js",
    "codeguard-setup": "dist/setup.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "guard": "node dist/cli.js guard",
    "check": "node dist/cli.js check",
    "test": "node test-mcp.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "claude",
    "claude-code",
    "code-analysis",
    "impact-analysis",
    "dependency-graph",
    "typescript",
    "prisma",
    "guard",
    "schema-check"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Skhaaall/codeguard.git"
  },
  "author": "Skhaall",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ts-morph": "^27.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  }
}
