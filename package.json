{
  "name": "skhaall-codeguard",
  "version": "0.2.2",
  "description": "MCP server — analyse de code TypeScript/Prisma, graphe de dependances, impact analysis pour Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "codeguard": "dist/index.js",
    "codeguard-cli": "dist/cli.js",
    "codeguard-setup": "dist/setup.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "guard": "node dist/cli.js guard",
    "check": "node dist/cli.js check",
    "test": "node test-mcp.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "claude",
    "claude-code",
    "code-analysis",
    "impact-analysis",
    "dependency-graph",
    "typescript",
    "prisma",
    "guard",
    "schema-check"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Skhaaall/codeguard.git"
  },
  "author": "Skhaall",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ts-morph": "^27.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
